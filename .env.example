# ============================================================
# QA Copilot AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# DATABASE (Required)
# PostgreSQL connection string
# Get a free database at: https://neon.tech
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------
# AUTH — better-auth (Required)
# Generate secret: openssl rand -base64 32
# BETTER_AUTH_URL must be your app's public URL
# ------------------------------------------------------------
BETTER_AUTH_SECRET=your-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:4000
AUTH_SECRET=your-random-32-char-secret-here
AUTH_URL=http://localhost:4000

# ------------------------------------------------------------
# AI — Google Gemini (Required for AI features)
# Get a free API key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIza...

# Hosted AI proxy token (set automatically in hosted Anything environments)
ANYTHING_PROJECT_TOKEN=

# ------------------------------------------------------------
# FILE UPLOADS — Uploadcare (Required for file/video uploads)
# Sign up free at: https://uploadcare.com
# ------------------------------------------------------------
NEXT_PUBLIC_UPLOADCARE_PUBLIC_KEY=your_uploadcare_public_key
UPLOADCARE_SECRET_KEY=your_uploadcare_secret_key

# ------------------------------------------------------------
# GOOGLE OAUTH (Optional — enables "Sign in with Google")
# Set up at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# PAYPAL — Sandbox checkout
# Create a REST app in the PayPal Developer Dashboard and paste its credentials.
# The sandbox merchant id below is the account receiving payments.
# ------------------------------------------------------------
PAYPAL_MODE=sandbox
PAYPAL_MERCHANT_ID=U4ZDWD2FJS956
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ------------------------------------------------------------
# ADMIN SETUP
# /admin-setup uses the fixed setup key shown on the page.
# ------------------------------------------------------------

# ------------------------------------------------------------
# APP URL (used internally for server-side fetch calls)
# Set to your production URL when deploying
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:4000
